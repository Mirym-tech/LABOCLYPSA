# ============================================================
# LABOCLYPSA — Variables de entorno
# Copiar este archivo como .env y completar los valores reales
# NUNCA subir .env a git/repositorio público
# ============================================================

# Puerto del servidor (por defecto 3000)
PORT=3000

# URL de tu proyecto en Supabase
# Ejemplo: https://xyzabcde.supabase.co
SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Service Role Key (clave de servicio con acceso total — NO la Anon Key)
# Supabase Dashboard > Settings > API > service_role
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL del frontend (para CORS — en desarrollo: http://localhost:5500)
FRONTEND_URL=http://localhost:5500

# Entorno: development | production
NODE_ENV=development
